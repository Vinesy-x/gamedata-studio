{
  "name": "gamedata-studio",
  "version": "1.3.16",
  "description": "GameData Studio — Excel Add-in for RPG/MMO game data management",
  "private": true,
  "scripts": {
    "start": "webpack serve --mode development",
    "build": "webpack --mode production",
    "deploy": "webpack --mode production --env channel=dev && npx gh-pages -d dist --dest dev --add -m \"Deploy dev v$(node -p \"require('./package.json').version\")\"",
    "deploy:release": "webpack --mode production && npx gh-pages -d dist --dest . --add -m \"Release v$(node -p \"require('./package.json').version\")\"",
    "test": "jest --passWithNoTests",
    "lint": "tsc --noEmit",
    "sideload": "npx office-addin-debugging start manifest.xml"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.54.0",
    "@fluentui/react-icons": "^2.0.230",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@types/file-saver": "^2.0.7",
    "@types/jest": "^29.5.0",
    "@types/office-js": "^1.0.377",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "babel-loader": "^9.1.0",
    "buffer": "^6.0.3",
    "copy-webpack-plugin": "^12.0.0",
    "css-loader": "^7.1.0",
    "html-webpack-plugin": "^5.6.0",
    "jest": "^29.7.0",
    "office-addin-dev-certs": "^1.13.0",
    "process": "^0.11.10",
    "stream-browserify": "^3.0.0",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.5.0",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^5.1.0"
  }
}
